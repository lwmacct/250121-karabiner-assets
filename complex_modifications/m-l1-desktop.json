      "manipulators": [
        {
          "description": "桌面1（q）",
          "type": "basic",
          "from": {
            "key_code": "q",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "1",
              "modifiers": [
                "left_control"
              ]
            },
            {
              "shell_command": "curl --silent --output /dev/null --max-time 0.2 'http://127.0.0.1:15098?param=Q-01'"
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            }
          ]
        },
