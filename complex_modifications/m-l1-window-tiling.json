{
  "title": "m-l1-window-tiling",
  "rules": [
    {
      "description": "（m-l1-window-tiling）第一层窗口磁贴（m 键二段切换）",
      "manipulators": [
        {
          "description": "cl+m（首次：最大化窗口）",
          "type": "basic",
          "from": {
            "key_code": "m",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "return_or_enter",
              "modifiers": [
                "left_control",
                "left_option"
              ]
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 1
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_cl_key_m",
              "value": 0
            }
          ]
        },
        {
          "description": "cl+m（再次：自定义窗口）",
          "type": "basic",
          "from": {
            "key_code": "m",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "m",
              "modifiers": [
                "left_control",
                "left_option"
              ]
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_cl_key_m",
              "value": 1
            }
          ]
        }
      ]
    }
  ]
}
