{
  "title": "m-keymap",
  "rules": [
    {
      "description": "（m-keymap）Left Shift 单击触发输入法切换（Ctrl+Space）",
      "manipulators": [
        {
          "description": "Left Shift 单击（发送 Ctrl+Space；长按或组合键不触发）",
          "type": "basic",
          "from": {
            "key_code": "left_shift"
          },
          "to": [
            {
              "key_code": "left_shift",
              "lazy": true
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 180
          },
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 0
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        }
      ]
    }
  ]
}
