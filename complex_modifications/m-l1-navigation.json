{
  "title": "m-l1-navigation",
  "rules": [
    {
      "description": "（m-l1-navigation）第一层 [ikjl] 上下左右",
      "manipulators": [
        {
          "description": "方向键上",
          "type": "basic",
          "from": {
            "key_code": "i"
          },
          "to": [
            {
              "key_code": "up_arrow",
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "方向键下",
          "type": "basic",
          "from": {
            "key_code": "k"
          },
          "to": [
            {
              "key_code": "down_arrow",
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "方向键左",
          "type": "basic",
          "from": {
            "key_code": "j"
          },
          "to": [
            {
              "key_code": "left_arrow",
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "方向键右",
          "type": "basic",
          "from": {
            "key_code": "l"
          },
          "to": [
            {
              "key_code": "right_arrow",
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        }
      ]
    },
    {
      "description": "（m-l1-navigation）第一层 [hn] 行首行尾",
      "manipulators": [
        {
          "description": "移动到行首",
          "type": "basic",
          "from": {
            "key_code": "h"
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": [
                "left_command"
              ],
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "移动到行尾",
          "type": "basic",
          "from": {
            "key_code": "n"
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": [
                "left_command"
              ],
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        }
      ]
    },
    {
      "description": "（m-l1-navigation）第一层 [uo] 左右选中",
      "manipulators": [
        {
          "description": "向左选中",
          "type": "basic",
          "from": {
            "key_code": "u"
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": [
                "left_shift"
              ],
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "向右选中",
          "type": "basic",
          "from": {
            "key_code": "o"
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": [
                "left_shift"
              ],
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        }
      ]
    },
    {
      "description": "（m-l1-navigation）第一层 Tab 切换（.,）",
      "manipulators": [
        {
          "description": "下一个（.）",
          "type": "basic",
          "from": {
            "key_code": "period"
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": [
                "left_control"
              ]
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "上一个（,）",
          "type": "basic",
          "from": {
            "key_code": "comma"
          },
          "to": [
            {
              "key_code": "tab",
              "modifiers": [
                "left_control",
                "left_shift"
              ]
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        }
      ]
    },
    {
      "description": "（m-l1-navigation）第一层窗口磁贴（m 键二段切换）",
      "manipulators": [
        {
          "description": "cl+m（首次：最大化窗口）",
          "type": "basic",
          "from": {
            "key_code": "m"
          },
          "to": [
            {
              "key_code": "return_or_enter",
              "modifiers": [
                "left_control",
                "left_option"
              ],
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 1
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_cl_key_m",
              "value": 0
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        },
        {
          "description": "cl+m（再次：自定义窗口）",
          "type": "basic",
          "from": {
            "key_code": "m"
          },
          "to": [
            {
              "key_code": "m",
              "modifiers": [
                "left_control",
                "left_option"
              ],
              "repeat": true
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_cl_key_m",
              "value": 1
            },
            {
              "type": "variable_if",
              "name": "lwm_l2_hold",
              "value": 0
            }
          ]
        }
      ]
    }
  ]
}
