{
  "title": "m-core-caps-state",
  "rules": [
    {
      "description": "（m-core-caps-state）模式切换：Caps 切换主层，L1+Space 进入第二层模式，Esc 退出",
      "manipulators": [
        {
          "description": "Caps：0 -> 1（进入第一层）",
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 1
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 0
            }
          ]
        },
        {
          "description": "Caps：1/2 -> 0（退出全部层）",
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 2
            }
          ]
        },
        {
          "description": "L1 + Space：进入第二层（预留模式）",
          "type": "basic",
          "from": {
            "key_code": "spacebar"
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 2
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            }
          ]
        },
        {
          "description": "Esc：退出第一层",
          "type": "basic",
          "from": {
            "key_code": "escape"
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            }
          ]
        },
        {
          "description": "Esc：退出第二层",
          "type": "basic",
          "from": {
            "key_code": "escape"
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 2
            }
          ]
        }
      ]
    }
  ]
}
