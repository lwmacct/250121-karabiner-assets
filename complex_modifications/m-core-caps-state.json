{
  "title": "m-core-caps-state",
  "rules": [
    {
      "description": "（m-core-caps-state）Caps 按住进入 L1，L1+Space 按住进入 L2，Caps 弹起清空状态",
      "manipulators": [
        {
          "description": "Caps 按住：进入第一层；Caps 弹起：退出全部层",
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "parameters": {
            "basic.to_if_held_down_threshold_milliseconds": 1
          },
          "to_if_held_down": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 1
              }
            },
            {
              "set_variable": {
                "name": "lwm_l2_hold",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "lwm_caps_lock",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_l2_hold",
                "value": 0
              }
            },
            {
              "set_variable": {
                "name": "lwm_cl_key_m",
                "value": 0
              }
            }
          ]
        },
        {
          "description": "L1 + Space 按住：进入第二层；Space 弹起：返回第一层",
          "type": "basic",
          "from": {
            "key_code": "spacebar"
          },
          "to": [
            {
              "set_variable": {
                "name": "lwm_l2_hold",
                "value": 1
              }
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "lwm_l2_hold",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "lwm_caps_lock",
              "value": 1
            }
          ]
        }
      ]
    }
  ]
}
