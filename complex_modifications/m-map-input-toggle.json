{
  "title": "m-map-input-toggle",
  "rules": [
    {
      "description": "（m-map-input-toggle）Left Shift 单击触发输入法切换（Ctrl+Space）",
      "manipulators": [
        {
          "description": "Left Shift 单击（发送 Ctrl+Space）",
          "type": "basic",
          "from": {
            "key_code": "left_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_shift",
              "lazy": true
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 250
          }
        }
      ]
    }
  ]
}
